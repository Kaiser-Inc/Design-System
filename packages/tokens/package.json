{
  "name": "@kaiserinc/tokens",
  "version": "0.2.0",
  "description": "KaiserInc design tokens — CSS custom properties e JS/TS exports",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./css": "./dist/index.css",
    "./colors": {
      "types": "./dist/colors.d.ts",
      "import": "./dist/colors.mjs",
      "require": "./dist/colors.js"
    },
    "./typography": {
      "types": "./dist/typography.d.ts",
      "import": "./dist/typography.mjs",
      "require": "./dist/typography.js"
    },
    "./spacing": {
      "types": "./dist/spacing.d.ts",
      "import": "./dist/spacing.mjs",
      "require": "./dist/spacing.js"
    },
    "./radii": {
      "types": "./dist/radii.d.ts",
      "import": "./dist/radii.mjs",
      "require": "./dist/radii.js"
    },
    "./shadows": {
      "types": "./dist/shadows.d.ts",
      "import": "./dist/shadows.mjs",
      "require": "./dist/shadows.js"
    },
    "./motion": {
      "types": "./dist/motion.d.ts",
      "import": "./dist/motion.mjs",
      "require": "./dist/motion.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsx scripts/build-css.ts",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@kaiserinc/eslint-config": "workspace:*",
    "@kaiserinc/typescript-config": "workspace:*",
    "eslint": "^9.17.0",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
