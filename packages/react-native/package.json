{
  "name": "@kaiserinc/react-native",
  "version": "0.1.0",
  "description": "KaiserInc React Native component library",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "dependencies": {
    "@kaiserinc/tokens": "workspace:*"
  },
  "devDependencies": {
    "@kaiserinc/typescript-config": "workspace:*",
    "@types/react": "^19.0.6",
    "@types/react-native": "^0.73.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  }
}
